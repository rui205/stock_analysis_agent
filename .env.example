# Anthropic API key — required for the LLM to function.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default Claude model. Defaults to claude-opus-4-8.
# CLAUDE_MODEL=claude-opus-4-8

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
# LOG_LEVEL=INFO
